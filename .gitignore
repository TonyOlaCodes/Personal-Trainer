# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
scripts/.cache/
*.pem
/tmp/
.cursor/
.agents/
.codex/

# local debug dumps (never commit)
/db-out.json
/exercise_list.txt
/git_status*.txt
/lint_*.txt
/*_lint.txt
/out.txt
/prisma_*.txt
/pub_size.txt
/test-prisma.js

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# clerk configuration (can include secrets)
/.clerk/

# user uploads
/public/uploads


.vercel
